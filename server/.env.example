# Server Configuration
PORT=4000

# Database Configuration
# Local: mongodb://localhost:27017/idlewheels
# Cloud: mongodb+srv://<username>:<password>@cluster.mongodb.net/idlewheels
MONGODB_URI=mongodb://localhost:27017/idlewheels

# Authentication
JWT_SECRET=your_jwt_secret_here
GOOGLE_CLIENT_ID=your_google_client_id_here

# AI / Chatbot (Optional)
LANGFLOW_FLOW_ID=your_langflow_flow_id_here
